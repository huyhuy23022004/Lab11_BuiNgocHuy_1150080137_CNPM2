<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
    testng-grid.xml - Chạy song song 4 luồng trên Selenium Grid
    Cho phép đo hiệu suất so sánh giữa 1, 2 và 4 luồng.
-->
<suite name="Selenium Grid Parallel Suite" parallel="methods" thread-count="4" verbose="2">

    <parameter name="browser" value="chrome"/>
    <parameter name="env" value="dev"/>

    <test name="Parallel Execution - 4 Threads">
        <classes>
            <class name="com.automation.tests.LoginTest"/>
            <class name="com.automation.tests.CartTest"/>
        </classes>
    </test>

</suite>
